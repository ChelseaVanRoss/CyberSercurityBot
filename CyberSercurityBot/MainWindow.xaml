<Window x:Class="CyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" 
        Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="🛡️ CYBERSECURITY AWARENESS BOT 🛡️"
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="#E94560"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Row="1" Background="#16213E" CornerRadius="10" Padding="10">
            <ScrollViewer x:Name="scrollViewer">
                <RichTextBox x:Name="rtbChat" 
                             IsReadOnly="True" 
                             Background="#16213E" 
                             BorderThickness="0"
                             FontSize="14"
                             Foreground="White"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#0F3460" CornerRadius="10" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtUserInput" 
                         Grid.Column="0"
                         FontSize="14" 
                         Padding="10" 
                         Background="#1A1A2E" 
                         Foreground="White"
                         BorderBrush="#E94560"
                         BorderThickness="1"/>

                <Button x:Name="btnSend" 
                        Grid.Column="1"
                        Content="Send" 
                        Width="70" 
                        Height="35" 
                        Margin="10,0,0,0"
                        Background="#E94560" 
                        Foreground="White"
                        FontWeight="Bold"
                        Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>