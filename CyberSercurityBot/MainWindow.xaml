<Window x:Class="CyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ Cybersecurity Awareness Bot - Part 3" 
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="🛡️ CYBERSECURITY AWARENESS BOT 🛡️"
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#E94560"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Tab Control for Chat and Quiz -->
        <TabControl Grid.Row="1" Background="#16213E" BorderThickness="0">

            <!-- TAB 1: Chatbot -->
            <TabItem Header="💬 Chatbot" Background="#1A1A2E" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat Display -->
                    <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Padding="10">
                        <ScrollViewer x:Name="scrollViewer">
                            <RichTextBox x:Name="rtbChat" 
                                         IsReadOnly="True" 
                                         Background="#16213E" 
                                         BorderThickness="0"
                                         FontSize="14"
                                         Foreground="White"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Input Area -->
                    <Border Grid.Row="1" Background="#0F3460" CornerRadius="10" Padding="10" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtUserInput" 
                                     Grid.Column="0"
                                     FontSize="14" 
                                     Padding="10" 
                                     Background="#1A1A2E" 
                                     Foreground="White"
                                     BorderBrush="#E94560"
                                     BorderThickness="1"/>

                            <Button x:Name="btnSend" 
                                    Grid.Column="1"
                                    Content="Send" 
                                    Width="70" 
                                    Height="35" 
                                    Margin="5,0"
                                    Background="#E94560" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Cursor="Hand"/>

                            <Button x:Name="btnClearChat" 
                                    Grid.Column="2"
                                    Content="Clear" 
                                    Width="70" 
                                    Height="35" 
                                    Margin="5,0"
                                    Background="#FF5722" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Cursor="Hand"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB 2: Quiz Game -->
            <TabItem Header="🎮 Quiz Game" Background="#1A1A2E" Foreground="White">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Quiz Title -->
                    <TextBlock Grid.Row="0" 
                               Text="🧠 Cybersecurity Quiz Challenge" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="#E94560"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <!-- Score Display -->
                    <Border Grid.Row="1" Background="#0F3460" CornerRadius="10" Padding="10" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="Score: 0/0" 
                                       x:Name="txtScore"
                                       FontSize="16" 
                                       Foreground="#4CAF50"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Left"/>

                            <TextBlock Grid.Column="1" 
                                       Text="Question X of X" 
                                       x:Name="txtProgress"
                                       FontSize="16" 
                                       Foreground="#FFC107"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Question Display -->
                    <Border Grid.Row="2" Background="#16213E" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                        <TextBlock x:Name="txtQuestion" 
                                   Text="Click 'Start Quiz' to begin!" 
                                   FontSize="18" 
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Answer Buttons -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,15">
                        <Button x:Name="btnAnswer1" 
                                Content="Answer 1" 
                                Height="40" 
                                Margin="0,5"
                                Background="#1A1A2E" 
                                Foreground="White"
                                BorderBrush="#E94560"
                                BorderThickness="1"
                                Cursor="Hand"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>

                        <Button x:Name="btnAnswer2" 
                                Content="Answer 2" 
                                Height="40" 
                                Margin="0,5"
                                Background="#1A1A2E" 
                                Foreground="White"
                                BorderBrush="#E94560"
                                BorderThickness="1"
                                Cursor="Hand"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>

                        <Button x:Name="btnAnswer3" 
                                Content="Answer 3" 
                                Height="40" 
                                Margin="0,5"
                                Background="#1A1A2E" 
                                Foreground="White"
                                BorderBrush="#E94560"
                                BorderThickness="1"
                                Cursor="Hand"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>

                        <Button x:Name="btnAnswer4" 
                                Content="Answer 4" 
                                Height="40" 
                                Margin="0,5"
                                Background="#1A1A2E" 
                                Foreground="White"
                                BorderBrush="#E94560"
                                BorderThickness="1"
                                Cursor="Hand"
                                FontSize="14"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Result Display -->
                    <Border Grid.Row="4" Background="#16213E" CornerRadius="10" Padding="10" Margin="0,0,0,15">
                        <TextBlock x:Name="txtResult" 
                                   Text="" 
                                   FontSize="16" 
                                   Foreground="#FFC107"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Start / Restart Button -->
                    <Button x:Name="btnStartQuiz" 
                            Grid.Row="5"
                            Content="🎯 Start Quiz" 
                            Height="45" 
                            Background="#E94560" 
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"
                            BorderThickness="0"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>